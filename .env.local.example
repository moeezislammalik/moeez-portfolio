# Copy this file to .env.local and fill in your keys.

# OpenAI — powers the "Ask Moeez" AI chatbot
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Formspree — sends contact form submissions to your inbox
# 1. Sign up at https://formspree.io
# 2. Create a form (set notification email to moeezislammalik@gmail.com)
# 3. Copy the form ID from the endpoint URL: https://formspree.io/f/YOUR_FORM_ID
FORMSPREE_FORM_ID=YOUR_FORM_ID
